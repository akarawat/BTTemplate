@{
    ViewData["Title"] = "Welcome";
    Layout = null; // No navbar needed before login
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BTTemplate — Sign In</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background:#f4f6fa; font-family:'Segoe UI',sans-serif; }
        .login-card {
            max-width:400px; margin:10vh auto; background:#fff;
            border-radius:14px; padding:40px; box-shadow:0 8px 32px rgba(13,71,161,.12);
            text-align:center;
        }
        .logo { width:64px; height:64px; background:#0d47a1; border-radius:16px;
                display:flex; align-items:center; justify-content:center;
                font-size:28px; color:#fff; margin:0 auto 20px; }
        .btn-sso {
            background:#0d47a1; color:#fff; border:none; padding:12px 32px;
            border-radius:8px; font-weight:700; font-size:15px; width:100%;
            transition:background .15s;
        }
        .btn-sso:hover { background:#0a3880; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo"><i class="bi bi-app-indicator"></i></div>
        <h4 class="fw-bold mb-1">BTTemplate</h4>
        <p class="text-muted mb-4" style="font-size:13.5px">
            Sign in with your Bernina Thailand account
        </p>
        <a href="/Dashboards/Index" class="btn-sso btn">
            <i class="bi bi-shield-check me-2"></i>Sign in with SSO
        </a>
        <div class="mt-4" style="font-size:12px;color:#90a4ae">
            You will be redirected to the Bernina Thailand<br>authentication server.
        </div>
    </div>
</body>
</html>
