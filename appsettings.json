{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // ── Main database connection ──────────────────────────────────────
    "MainConn": "Server=BTDB04;Initial Catalog=YOUR_DATABASE;Persist Security Info=False;User ID=YOUR_USER;Password=YOUR_PASSWORD;MultipleActiveResultSets=False;Encrypt=False;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "TBCorApiServices": {
    // ── Application Info ─────────────────────────────────────────────
    "AppName":    "My Application",
    "AppVersion": "1.0",

    // ── SSO ──────────────────────────────────────────────────────────
