    "URLSITE":   "https://YOUR_APP_URL/",

    // ── Email ─────────────────────────────────────────────────────────
    "EmailSender": "https://btapi.berninathailand.com/EmailSender/EmailSender/",
    "MailForm":    "noreply@berninathailand.com",
    "MailDebug":   "1",

    // ── Misc ──────────────────────────────────────────────────────────
    "MaxFileSize": 2000000,
    "Page20":      20
  }
}
